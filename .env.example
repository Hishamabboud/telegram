# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  MISSILE ALERT BOT — Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ─── STEP 1: Telegram Bot (for POSTING to your channel) ───
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=7123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your channel: "@mychannel" for public, or "-100xxxxxxxxxx" for private
TELEGRAM_CHANNEL_ID=@your_channel_name

# ─── STEP 2: Telegram User API (for READING Israeli channels) ───
# Get from https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# Your personal phone number (used once for login)
TELEGRAM_PHONE=+31612345678

# ─── Optional ───
LOG_LEVEL=INFO
